{
  "manifest_version": 3,
  "name": "Rohlik Score",
  "version": "1.0.0",
  "description": "Adds Nutri-Score health ratings to every product on rohlik.cz",
  "permissions": [
    "storage",
    "tabs"
  ],
  "host_permissions": [
    "*://*.rohlik.cz/*",
    "*://world.openfoodfacts.org/*"
  ],
  "background": {
    "service_worker": "background.js",
    "scripts": ["background.js"]
  },
  "content_scripts": [
    {
      "matches": ["*://*.rohlik.cz/*"],
      "js": ["content.js"],
      "css": ["content.css"],
      "run_at": "document_idle"
    }
  ],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "48": "icons/icon-48.png",
      "96": "icons/icon-96.png",
      "128": "icons/icon-128.png"
    },
    "default_title": "Rohlik Score"
  },
  "icons": {
    "48": "icons/icon-48.png",
    "96": "icons/icon-96.png",
    "128": "icons/icon-128.png"
  },
  "browser_specific_settings": {
    "gecko": {
      "id": "rohlikhealth@extension",
      "strict_min_version": "128.0",
      "data_collection_permissions": {
        "required": ["none"],
        "optional": []
      }
    }
  }
}
